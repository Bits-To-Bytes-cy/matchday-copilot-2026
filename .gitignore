# ========================
# MatchDay Copilot - .gitignore
# ========================

# --- Environment & Secrets ---
.env
.env.local
.env.production
.env.*.local

# --- Dependencies ---
node_modules/
package-lock.json

# --- OS System Files ---
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory

# --- IDE & Editor Files ---
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# --- Build & Logs ---
dist/
build/
*.log
npm-debug.log*
